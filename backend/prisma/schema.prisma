datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id                String       @id @default(uuid())
  firebaseUid       String       @unique
  email             String       @unique
  displayName       String
  bio               String?      @db.Text
  avatarUrl         String?
  nickname          String?
  phone             String?
  studentCode       String?
  role              Role?        @relation(fields: [roleId], references: [id])
  roleId            String?
  fcmToken          String?
  totalPoints       Int          @default(0)
  facultyId         Int?
  isActive          Boolean      @default(true)
  ideas             Idea[]
  ideaLikes         IdeaLike[]
  comments          Comment[]
  evaluations       Evaluation[]
  challenges        Challenge[]  @relation("AuthorChallenges")
  accessedPrivateChallenges Challenge[] @relation("UserAccessedPrivateChallenges")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Challenge {
  id                 String   @id @default(uuid())
  title              String
  problemDescription String?  @db.Text
  companyContext     String?  @db.Text
  participationRules String?  @db.Text
  startDate          DateTime?
  endDate            DateTime?
  publicationDate    DateTime?
  isPrivate          Boolean  @default(false)
  accessToken        String?  @unique
  facultyId          Int?
  status             String   @default("DRAFT")
  author             User     @relation("AuthorChallenges", fields: [authorId], references: [id])
  authorId           String
  ideas              Idea[]
  accessedByUsers    User[]   @relation("UserAccessedPrivateChallenges")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Idea {
  id            String       @id @default(uuid())
  title         String
  problem       String       @db.Text
  solution      String       @db.Text
  status        String       @default("draft")
  votesCount    Int          @default(0)
  likesCount    Int          @default(0)
  commentsCount Int          @default(0)
  isAnonymous   Boolean      @default(false)
  tags          String[]     @default([])
  author        User         @relation(fields: [authorId], references: [id])
  authorId      String
  challenge     Challenge    @relation(fields: [challengeId], references: [id])
  challengeId   String
  evaluations   Evaluation[]
  comments      Comment[]
  ideaLikes     IdeaLike[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([challengeId])
  @@index([authorId])
  @@index([status])
  @@index([challengeId, status, createdAt])  
  @@index([challengeId, likesCount])          
}

model Comment {
  id               String    @id @default(uuid())
  content          String    @db.Text
  author           User      @relation(fields: [authorId], references: [id])
  authorId         String
  idea             Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  ideaId           String
  parentComment    Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  parentCommentId  String?
  replies          Comment[] @relation("CommentReplies")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  editedAt         DateTime?
  deletedAt        DateTime?
  status           String    @default("visible")

  @@index([ideaId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([status])
}

model Evaluation {
  id        String   @id @default(uuid())
  idea      Idea     @relation(fields: [ideaId], references: [id])
  ideaId    String
  judge     User     @relation(fields: [judgeId], references: [id])
  judgeId   String
  score     Int
  feedback  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ideaId])
  @@index([judgeId])
}

model IdeaLike {
  id        String   @id @default(uuid())
  idea      Idea     @relation(fields: [ideaId], references: [id])
  ideaId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())

  @@unique([ideaId, userId])
  @@index([ideaId])
  @@index([userId])
}
