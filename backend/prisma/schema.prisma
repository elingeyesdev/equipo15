datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  COMPANY
  JUDGE
  USER
}

enum UserStatus {
  ACTIVE
  SOFT_BLOCK
  SUSPENDED
}

enum ReactionType {
  GOOD
  FUTURE
  COMPLEX
}

enum ImpactArea {
  PRODUCTIVITY
  COSTS
  CUSTOMERS
  TEAM
  GROWTH
  SUSTAINABILITY
  SOCIAL_IMPACT
}

enum ImprovementType {
  OPTIMIZES
  ENHANCES
  EXPANDS
  TRANSFORMS
}

enum EffortLevel {
  EASY
  COORDINATION
  DEVELOPMENT
  TRANSFORMATION
}

model User {
  id                        String         @id @default(uuid())
  firebaseUid               String         @unique
  email                     String         @unique
  displayName               String
  bio                       String?        @db.Text
  avatarUrl                 String?
  nickname                  String?
  phone                     String?
  studentCode               String?
  role                      UserRole       @default(USER)
  fcmToken                  String?
  totalPoints               Int            @default(0)
  faculty                   Faculty?       @relation(fields: [facultyId], references: [id])
  facultyId                 String?
  likeRemovalCount          Int            @default(0)
  commentEditCount          Int            @default(0)
  commentDeleteCount        Int            @default(0)
  isActive                  Boolean        @default(true)
  status                    UserStatus     @default(ACTIVE)
  penaltyExpiresAt          DateTime?
  ideas                     Idea[]
  ideaLikes                 IdeaLike[]
  ideaFavorites             IdeaFavorite[]
  comments                  Comment[]
  evaluations               Evaluation[]
  challenges                Challenge[]    @relation("AuthorChallenges")
  accessedPrivateChallenges Challenge[]    @relation("UserAccessedPrivateChallenges")
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
}

model Challenge {
  id                 String    @id @default(uuid())
  title              String
  problemDescription String?   @db.Text
  companyContext     String?   @db.Text
  participationRules String?   @db.Text
  startDate          DateTime?
  endDate            DateTime?
  publicationDate    DateTime?
  isPrivate          Boolean   @default(false)
  accessToken        String?   @unique
  faculty            Faculty?  @relation(fields: [facultyId], references: [id])
  facultyId          String?
  status             String    @default("DRAFT")
  podiumSize         Int?
  logoUrl            String?   @db.Text
  evaluationCriteria Json?
  targetAudience     Json?
  author             User      @relation("AuthorChallenges", fields: [authorId], references: [id])
  authorId           String
  ideas              Idea[]
  accessedByUsers    User[]    @relation("UserAccessedPrivateChallenges")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Idea {
  id               String           @id @default(uuid())
  title            String
  problem          String           @db.Text
  solution         String           @db.Text
  status           String           @default("draft")
  /// finalScore = Σ (criterio.weight/100 * evaluationScore.score) promediado entre jueces
  finalScore       Float            @default(0)
  likesCount       Int              @default(0)
  goodCount        Int              @default(0)
  futureCount      Int              @default(0)
  complexCount     Int              @default(0)
  fireScore        Float            @default(0)
  commentsCount    Int              @default(0)
  favoritesCount   Int              @default(0)
  isAnonymous      Boolean          @default(false)
  tags             String[]         @default([])
  impactArea       ImpactArea?
  improvementType  ImprovementType?
  effortLevel      EffortLevel?
  author           User             @relation(fields: [authorId], references: [id])
  authorId         String
  challenge        Challenge        @relation(fields: [challengeId], references: [id])
  challengeId      String
  evaluations      Evaluation[]
  comments         Comment[]
  ideaLikes        IdeaLike[]
  ideaFavorites    IdeaFavorite[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([challengeId])
  @@index([authorId])
  @@index([status])
  @@index([challengeId, status, createdAt])
  @@index([challengeId, likesCount])
}

model Comment {
  id              String    @id @default(uuid())
  content         String    @db.Text
  author          User      @relation(fields: [authorId], references: [id])
  authorId        String
  idea            Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  ideaId          String
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  parentCommentId String?
  replies         Comment[] @relation("CommentReplies")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  editedAt        DateTime?
  deletedAt       DateTime?
  status          String    @default("visible")
  editCount       Int       @default(0)

  @@index([ideaId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([status])
}

model Evaluation {
  id        String   @id @default(uuid())
  idea      Idea     @relation(fields: [ideaId], references: [id])
  ideaId    String
  judge     User     @relation(fields: [judgeId], references: [id])
  judgeId   String
  score     Int
  feedback  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ideaId])
  @@index([judgeId])
}

model IdeaLike {
  id        String   @id @default(uuid())
  idea      Idea     @relation(fields: [ideaId], references: [id])
  ideaId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  reactionType ReactionType @default(GOOD)
  createdAt DateTime @default(now())

  @@unique([ideaId, userId])
  @@index([ideaId])
  @@index([userId])
}

model IdeaFavorite {
  id        String   @id @default(uuid())
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  ideaId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([ideaId, userId])
  @@index([ideaId])
  @@index([userId])
}

model Faculty {
  id            String   @id @default(uuid())
  name          String
  institutionId String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users      User[]
  challenges Challenge[]

  @@unique([name, institutionId])
  @@map("faculties")
}

model AllowedDomain {
  id        String   @id @default(uuid())
  domain    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("allowed_domains")
  @@index([domain])
}
