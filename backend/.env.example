# ─── Backend Environment Variables ───
# Copy this file to .env and fill in the values

# PostgreSQL Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/pista8

# Server
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
# Place your firebase-admin.json service account key in the project root
GOOGLE_APPLICATION_CREDENTIALS=firebase-admin.json

# Optional: Current event scale / edition
CURRENT_SCALE=8
