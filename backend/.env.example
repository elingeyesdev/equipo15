# ============================================================
# PISTA 8 — BACKEND | Variables de entorno
# Copia este archivo como .env y completa los valores secretos
# NUNCA subas el .env al repositorio (ya está en .gitignore)
# ============================================================

# ── PostgreSQL (Docker local — reemplaza Supabase) ──────────
# Dentro de Docker: el host es 'postgres' (nombre del servicio en compose)
# Desarrollo sin Docker (npm run start:dev): cambiar 'postgres' → 'localhost'
DATABASE_URL="postgresql://pista8_user:pista8_pass@postgres:5432/pista8_db?schema=public"

# ── MongoDB Atlas ────────────────────────────────────────────
# Datos compartidos en la nube para todo el equipo
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pista8_db?retryWrites=true&w=majority

# ── Prisma engines (compatibilidad Windows) ──────────────────
PRISMA_CLIENT_ENGINE_TYPE=library
PRISMA_CLI_QUERY_ENGINE_TYPE=library

# ── Firebase Admin SDK ───────────────────────────────────────
FIREBASE_PROJECT_ID=pista8-f8e6e
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── App ──────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=cambia_esto_por_una_clave_segura_minimo_32_caracteres